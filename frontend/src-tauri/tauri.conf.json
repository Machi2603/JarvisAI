{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis",
  "version": "1.2.1",
  "identifier": "ai.jarvis.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Jarvis",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:*; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "resources": ["resources/python/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Voice-first AI assistant for Windows",
    "longDescription": "Jarvis is a native voice-first AI assistant with wake-word activation, a visual neural sphere, chat, browser control, memory and automatic updates.",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": "-"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Spanish", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzNDI2NjQzMTQ1Qzc4MzAKUldRd2VGd1VRMlpDUS9rdVQ0RzcyNVo5UXpvWXBFL01POVkwZFErZXcvMU9zUFE4NkFOMGdPWWMK",
      "endpoints": [
        "https://github.com/Machi2603/JarvisAI/releases/download/desktop-latest/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["jarvisai"]
      }
    }
  }
}
